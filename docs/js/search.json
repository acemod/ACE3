---
layout: null
---
[
{% assign wikiPages = site.pages | where: "parent", "wiki" | sort: "title" %}
{% for curPage in wikiPages %}
    {
        "title"         : {{ curPage.title | jsonify }},
        "group"         : {{ curPage.group | jsonify }},
        "description"   : {{ curPage.description | jsonify }},
        "url"           : {{ site.baseurl | append: curPage.url | jsonify }},
        "content"       : {{ curPage.content | strip_html | normalize_whitespace | replace: '\\', ' ' | downcase | jsonify }}
    }{% unless forloop.last %},{% endunless %}
{% endfor %}
]
